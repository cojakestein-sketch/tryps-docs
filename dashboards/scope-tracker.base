views:
  - type: table
    name: Scope Tracker
    source:
      type: folder
      config:
        path: scopes
        includeSubfolders: true
    filters:
      - field: file.name
        operator: is
        value: state
    fields:
      - field: id
        width: 160
      - field: status
        width: 120
      - field: assignee
        width: 100
      - field: criteria
        width: 100
      - field: last_updated
        width: 120
    sort:
      - field: status
        order: asc
